# Azure OpenAI (target model + judge model)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT_TARGET=gpt-4o
AZURE_OPENAI_DEPLOYMENT_JUDGE=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-10-21

# Azure AI Content Safety (Prompt Shields) — needed Day 3
AZURE_CONTENT_SAFETY_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_CONTENT_SAFETY_KEY=

# Azure AI Foundry project — for hosting target agents
AZURE_FOUNDRY_PROJECT_ENDPOINT=
AZURE_FOUNDRY_PROJECT_NAME=agentsentry-targets

# Application Insights — telemetry
APPLICATIONINSIGHTS_CONNECTION_STRING=

# Microsoft Entra (when deploying to Azure)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# AgentSentry config
AGENTSENTRY_ENV=local
AGENTSENTRY_LOG_LEVEL=INFO
AGENTSENTRY_STORAGE_BACKEND=memory  # memory | cosmos
AGENTSENTRY_COSMOS_CONNECTION_STRING=

# Demo target — set to "mock" for the offline vulnerable agent, or a real endpoint URL
AGENTSENTRY_DEMO_TARGET=mock
